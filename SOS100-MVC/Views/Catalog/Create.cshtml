@model SOS100_MVC.Models.Item

@{
    ViewData["Title"] = "Lägg till nytt objekt";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Registrera ny pryl</h3>
                </div>
                <div class="card-body p-4">
                    
                    <form asp-action="Create" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Namn på objektet</label>
                            <input asp-for="Name" class="form-control" placeholder="T.ex. Skruvdragare" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label fw-bold">Kategori (0=Elektronik, 1=Bok, 2=Rapport, 3=Annat)</label>
                            <input asp-for="Type" class="form-control" type="number" required />
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Beskrivning</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Beskriv prylen och dess skick..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Placement" class="form-label fw-bold">Plats / Förvaring</label>
                            <input asp-for="Placement" class="form-control" placeholder="T.ex. Hylla A3" />
                            <span asp-validation-for="Placement" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PurchaseDate" class="form-label fw-bold">Inköpsdatum</label>
                            <input asp-for="PurchaseDate" class="form-control" type="date" required />
                            <span asp-validation-for="PurchaseDate" class="text-danger"></span>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Avbryt</a>
                            <button type="submit" class="btn btn-primary px-4">Spara objekt</button>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>