@model SOS100_MVC.Models.Item

@{
    ViewData["Title"] = "Ta bort " + Model.Name;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-danger shadow-sm" role="alert">
                <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Varning!</h4>
                <p>Är du helt säker på att du vill ta bort <strong>@Model.Name</strong> från katalogen?</p>
                <hr>
                <p class="mb-0">Denna åtgärd går inte att ångra.</p>
            </div>

            <div class="card shadow">
                <div class="card-body">
                    <h5 class="card-title">@Model.Name</h5>
                    <h6 class="card-subtitle mb-2 text-muted">Kategori: @Model.Type</h6>
                    <p class="card-text">@Model.Description</p>
                    <p class="card-text"><small class="text-muted">Inköpt: @Model.PurchaseDate.ToShortDateString()</small></p>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Avbryt</a>
                    
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger fw-bold">Ta bort</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>