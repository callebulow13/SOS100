@model IEnumerable<SOS100_MVC.Models.Item>

@{
    ViewData["Title"] = "Katalogen";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Katalog av objekt</h2>
        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">+ Lägg till nytt objekt</a>
        }

    </div>
    @if (Model != null && Model.Any())
    {
        <div class="row text-center mb-4">
            <div class="col-md-3 mb-2">
                <div class="card shadow-sm border-primary border-bottom border-3">
                    <div class="card-body py-3">
                        <h6 class="card-title text-muted text-uppercase fw-bold mb-1">Antal objekt</h6>
                        <h2 class="mb-0 text-primary fw-bold">@Model.Count()</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-2">
                <div class="card shadow-sm border-success border-bottom border-3">
                    <div class="card-body py-3">
                        <h6 class="card-title text-muted text-uppercase fw-bold mb-1">Tillgängliga</h6>
                        <h2 class="mb-0 text-success fw-bold">
                            @Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Tillgänglig)
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-2">
                <div class="card shadow-sm border-warning border-bottom border-3">
                    <div class="card-body py-3">
                        <h6 class="card-title text-muted text-uppercase fw-bold mb-1">Utlånade</h6>
                        <h2 class="mb-0 text-warning fw-bold">
                            @Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Utlånad)
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-2">
                <div class="card shadow-sm border-danger border-bottom border-3">
                    <div class="card-body py-3">
                        <h6 class="card-title text-muted text-uppercase fw-bold mb-1">Trasiga / Saknas</h6>
                        <h2 class="mb-0 text-danger fw-bold">
                            @Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Trasig || i.Status == SOS100_MVC.Models.ItemStatus.Saknas)
                        </h2>
                    </div>
                </div>
            </div>
        </div>
    }
    <hr/>
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8">
            <label for="searchInput" class="form-label fw-bold text-secondary px-1">Sök i katalogen</label>
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-primary text-white border-primary" id="search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                    </svg>
                </span>
                
                <input type="text" id="searchInput" class="form-control border-primary" placeholder="T.ex. Skruvdragare, Bok, Elektronik..." aria-label="Sök" aria-describedby="search-icon" />
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
            <tr>
                <th>Namn</th>
                <th>Kategori</th>
                <th>Status</th>
                <th class="text-end">Åtgärd</th> </tr>
            </thead>
            <tbody id="tableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="align-middle"> <td class="fw-bold">@item.Name</td>
                        <td>@item.Type</td>
                        <td>
                            @switch (item.Status)
                            {
                                case SOS100_MVC.Models.ItemStatus.Tillgänglig:
                                    <span class="badge bg-success">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Trasig:
                                    <span class="badge bg-danger">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Saknas:
                                    <span class="badge bg-secondary">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Utlånad:
                                default:
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                    break;
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                Detaljer
                            </a>
                            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm ms-1">
                                    Redigera
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm ms-1">
                                    Ta bort
                                </a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        <em>Katalogen är tom eller kunde inte laddas från API:et.</em>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        // Leta upp sökrutan och tabellen
        const searchInput = document.getElementById('searchInput');
        const tableBody = document.getElementById('tableBody');

        // Lyssna på varje gång användaren skriver något (input)
        searchInput.addEventListener('input', function () {
            // Hämta det användaren skrev och gör allt till små bokstäver
            const filter = searchInput.value.toLowerCase();
            // Hämta alla rader i tabellen
            const rows = tableBody.getElementsByTagName('tr');

            // Gå igenom varje rad en och en
            for (let i = 0; i < rows.length; i++) {
                // Hämta texten från kolumn 1 (Namn) och kolumn 2 (Kategori)
                let nameColumn = rows[i].getElementsByTagName('td')[0];
                let categoryColumn = rows[i].getElementsByTagName('td')[1];

                if (nameColumn || categoryColumn) {
                    let nameText = nameColumn.textContent || nameColumn.innerText;
                    let categoryText = categoryColumn.textContent || categoryColumn.innerText;

                    // Om texten i namnet eller kategorin matchar sökordet, visa raden
                    if (nameText.toLowerCase().indexOf(filter) > -1 || categoryText.toLowerCase().indexOf(filter) > -1) {
                        rows[i].style.display = ""; // Visa raden
                    } else {
                        rows[i].style.display = "none"; // Göm raden
                    }
                }
            }
        });
    </script>
}