@model IEnumerable<SOS100_MVC.Models.Item>

@{
    ViewData["Title"] = "Katalogen";
}

<style>
    /* Mjukare bakgrund på hela sidan för att låta vita boxar poppa */
    body {
        background-color: #f4f7f6;
    }

    /* Tabell-design */
    .table-container {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
    }

    /* Lite mörkare tabellhuvud för starkare kontrast */
    .table thead th {
        background-color: #e9ecef; 
        color: #495057; 
        border-bottom: 2px solid #dee2e6;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        padding: 15px;
    }

    .table tbody tr {
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.04) !important;
    }

    .status-badge {
        padding: 0.4em 0.8em;
        border-radius: 50px;
        font-weight: 500;
        font-size: 0.85rem;
    }
    
    /* Skräddarsydd design för filterknapparna */
    .filter-btn {
        background-color: #ffffff;
        color: #495057;
        transition: all 0.2s ease-in-out;
    }

    .filter-btn:hover {
        background-color: #f8f9fa;
        color: #212529;
    }

    .btn-check:checked + .filter-btn {
        background-color: #495057 !important;
        color: #ffffff !important;
        border-color: #495057 !important;
    }
</style>

<div class="container mt-4 mb-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Katalogen</h2>
            <p class="text-muted small mb-0">Översikt och hantering av resurser.</p>
        </div>
        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="bi bi-plus-lg me-1"></i> Nytt objekt
            </a>
        }
    </div>

    <div class="mb-5 mt-2">
        <div class="row justify-content-center mb-4">
            <div class="col-md-8 col-lg-6">
                <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden bg-white border-0">
                    <span class="input-group-text bg-transparent border-0 pe-2"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchInput" class="form-control border-0 fs-6 bg-transparent" style="box-shadow: none;" placeholder="Sök efter objekt..">
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap justify-content-center gap-2 align-items-center">
            
            <input type="checkbox" class="btn-check category-filter" id="cat-elektronik" value="Elektronik">
            <label class="btn filter-btn shadow-sm rounded-pill px-3 fw-medium border-0" for="cat-elektronik"><i class="bi bi-laptop me-1"></i> Elektronik</label>

            <input type="checkbox" class="btn-check category-filter" id="cat-bok" value="Bok">
            <label class="btn filter-btn shadow-sm rounded-pill px-3 fw-medium border-0" for="cat-bok"><i class="bi bi-book me-1"></i> Bok</label>

            <input type="checkbox" class="btn-check category-filter" id="cat-rapport" value="Rapport">
            <label class="btn filter-btn shadow-sm rounded-pill px-3 fw-medium border-0" for="cat-rapport"><i class="bi bi-file-earmark-text me-1"></i> Rapport</label>

            <input type="checkbox" class="btn-check category-filter" id="cat-annat" value="Annat">
            <label class="btn filter-btn shadow-sm rounded-pill px-3 fw-medium border-0" for="cat-annat"><i class="bi bi-box-seam me-1"></i> Annat</label>
        </div>
    </div>

    <div>
        <div class="d-flex justify-content-end mb-2 pe-1">
            <div class="form-check form-switch mb-0 d-flex align-items-center">
                <input class="form-check-input cursor-pointer m-0 border-secondary shadow-sm" type="checkbox" role="switch" id="availableOnlyCheck">
                <label class="form-check-label text-secondary fw-bold small ms-2 text-uppercase" for="availableOnlyCheck" style="margin-top: 2px; letter-spacing: 0.5px;">
                    Visa endast tillgängliga objekt
                </label>
            </div>
        </div>

        <div class="table-container shadow-sm border-0 mb-4">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Namn</th>
                        <th>Kategori</th>
                        <th>Plats / Förvaring</th>
                        <th>Status</th>
                        <th class="text-end">Åtgärder</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @foreach (var item in Model)
                    {
                        string statusClass = item.Status switch
                        {
                            SOS100_MVC.Models.ItemStatus.Tillgänglig => "bg-success-subtle text-success border border-success",
                            SOS100_MVC.Models.ItemStatus.Utlånad => "bg-warning-subtle text-warning-emphasis border border-warning",
                            SOS100_MVC.Models.ItemStatus.Trasig => "bg-danger-subtle text-danger border border-danger",
                            _ => "bg-secondary-subtle text-secondary border border-secondary"
                        };

                        string typeIcon = item.Type switch
                        {
                            SOS100_MVC.Models.ItemType.Bok => "bi-book",
                            SOS100_MVC.Models.ItemType.Elektronik => "bi-laptop",
                            SOS100_MVC.Models.ItemType.Rapport => "bi-file-earmark-text",
                            _ => "bi-box-seam"
                        };

                        <tr data-status="@item.Status" data-type="@item.Type">
                            <td class="fw-bold">@item.Name</td>
                            <td>
                                <i class="bi @typeIcon fs-5 me-2 text-dark"></i> 
                                @item.Type
                            </td>
                            <td class="fw-medium text-dark">@item.Placement</td>
                            <td>
                                <span class="status-badge @statusClass">@item.Status</span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    
                                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Ta bort">
                                            <i class="bi bi-x-lg"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm rounded-circle" title="Redigera">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    }
                                    
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary shadow-sm rounded-circle" title="Visa detaljer">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (Model != null && Model.Any())
        {
            <div class="d-flex flex-wrap justify-content-center justify-content-md-start align-items-center gap-3 gap-md-4 px-3 py-2">
                <div class="d-flex align-items-baseline">
                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Totalt:</span>
                    <span class="ms-2 fw-bold text-dark fs-6">@Model.Count()</span>
                </div>
                
                <div class="vr text-secondary opacity-25"></div>
                
                <div class="d-flex align-items-baseline">
                    <span class="text-success text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Tillgängliga:</span>
                    <span class="ms-2 fw-bold text-success fs-6">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Tillgänglig)</span>
                </div>
                
                <div class="vr text-secondary opacity-25 d-none d-sm-block"></div>
                
                <div class="d-flex align-items-baseline">
                    <span class="text-warning text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Utlånade:</span>
                    <span class="ms-2 fw-bold text-warning fs-6">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Utlånad)</span>
                </div>
                
                <div class="vr text-secondary opacity-25 d-none d-sm-block"></div>
                
                <div class="d-flex align-items-baseline">
                    <span class="text-danger text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Trasiga / Saknas:</span>
                    <span class="ms-2 fw-bold text-danger fs-6">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Trasig || i.Status == SOS100_MVC.Models.ItemStatus.Saknas)</span>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const availableOnlyCheck = document.getElementById('availableOnlyCheck');
        const categoryFilters = document.querySelectorAll('.category-filter');
        const rows = document.querySelectorAll('#tableBody tr');

        function filterTable() {
            const filterText = searchInput.value.toLowerCase();
            const showOnlyAvailable = availableOnlyCheck.checked;
            
            const selectedCategories = Array.from(categoryFilters)
                .filter(cb => cb.checked)
                .map(cb => cb.value);

            rows.forEach(row => {
                const rowText = row.textContent.toLowerCase();
                const rowStatus = row.getAttribute('data-status');
                const rowType = row.getAttribute('data-type');

                const matchesText = rowText.includes(filterText);
                const matchesStatus = showOnlyAvailable ? rowStatus === 'Tillgänglig' : true;
                const matchesCategory = selectedCategories.length === 0 || selectedCategories.includes(rowType);

                if (matchesText && matchesStatus && matchesCategory) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        searchInput.addEventListener('input', filterTable);
        availableOnlyCheck.addEventListener('change', filterTable);
        categoryFilters.forEach(cb => cb.addEventListener('change', filterTable));
    </script>
}