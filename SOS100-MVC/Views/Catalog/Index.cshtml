@model IEnumerable<SOS100_MVC.Models.Item>

@{
    ViewData["Title"] = "Katalogen";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Katalog av objekt</h2>
        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">+ Lägg till nytt objekt</a>
        }

    </div>
    
    <hr/>
    <div class="mb-4">
        <div class="row">
            <div class="col-md-6">
                <input type="text" id="searchInput" class="form-control shadow-sm" placeholder="Sök efter namn eller kategori..." />
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
            <tr>
                <th>Namn</th>
                <th>Kategori</th>
                <th>Status</th>
                <th class="text-end">Åtgärd</th> </tr>
            </thead>
            <tbody id="tableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="align-middle"> <td class="fw-bold">@item.Name</td>
                        <td>@item.Type</td>
                        <td>
                            @switch (item.Status)
                            {
                                case SOS100_MVC.Models.ItemStatus.Tillgänglig:
                                    <span class="badge bg-success">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Trasig:
                                    <span class="badge bg-danger">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Saknas:
                                    <span class="badge bg-secondary">@item.Status</span>
                                    break;
                                case SOS100_MVC.Models.ItemStatus.Utlånad:
                                default:
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                    break;
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                Visa detaljer
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        <em>Katalogen är tom eller kunde inte laddas från API:et.</em>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        // Leta upp sökrutan och tabellen
        const searchInput = document.getElementById('searchInput');
        const tableBody = document.getElementById('tableBody');

        // Lyssna på varje gång användaren skriver något (input)
        searchInput.addEventListener('input', function () {
            // Hämta det användaren skrev och gör allt till små bokstäver
            const filter = searchInput.value.toLowerCase();
            // Hämta alla rader i tabellen
            const rows = tableBody.getElementsByTagName('tr');

            // Gå igenom varje rad en och en
            for (let i = 0; i < rows.length; i++) {
                // Hämta texten från kolumn 1 (Namn) och kolumn 2 (Kategori)
                let nameColumn = rows[i].getElementsByTagName('td')[0];
                let categoryColumn = rows[i].getElementsByTagName('td')[1];

                if (nameColumn || categoryColumn) {
                    let nameText = nameColumn.textContent || nameColumn.innerText;
                    let categoryText = categoryColumn.textContent || categoryColumn.innerText;

                    // Om texten i namnet eller kategorin matchar sökordet, visa raden
                    if (nameText.toLowerCase().indexOf(filter) > -1 || categoryText.toLowerCase().indexOf(filter) > -1) {
                        rows[i].style.display = ""; // Visa raden
                    } else {
                        rows[i].style.display = "none"; // Göm raden
                    }
                }
            }
        });
    </script>
}