@model SOS100_MVC.Models.User?
@using SOS100_MVC.Models
@using SOS100_MVC.Dtos

@{
ViewData["Title"] = "Mina sidor";
var reminders = ViewBag.Reminders as List<Reminder> ?? new List<Reminder>();
var watches = ViewBag.Watches as List<Watch> ?? new List<Watch>();
var activeLoans = ViewBag.ActiveLoans as List<LoanDto> ?? new List<LoanDto>();
}

<style>
    /* --- ENDAST NOTIFIKATIONER / POPUP KVAR HÄR --- */
    .k-notifications {
        position: relative;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: white;
        border: 1px solid #dee2e6;
        transition: background 0.2s;
    }

    .k-notifications:hover {
        background: #e9ecef;
    }

    .k-notifications svg {
        color: #212529;
    }

    .k-notification-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #dc3545;
        color: white;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #f8f9fa;
    }

    .k-popup {
        display: none;
        position: absolute;
        top: 50px;
        right: 0;
        width: 450px;
        background: white;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        z-index: 1000;
        cursor: default;
        overflow: hidden;
    }

    .k-popup.show { display: block; }

    .k-popup-header {
        padding: 16px;
        border-bottom: 1px solid #e9ecef;
        font-weight: 700;
        font-size: 16px;
        color: #212529;
        background: #f8f9fa;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .k-popup-body {
        max-height: 500px;
        overflow-y: auto;
    }

    .k-popup-item {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .k-popup-item:last-child { border-bottom: none; }
    .k-popup-item:hover { background: #fdfdfe; }

    .k-popup-item-title { font-size: 15px; font-weight: 600; color: #212529; }
    .k-popup-item-date { font-size: 13px; color: #6c757d; }
</style>

<div class="container-fluid mt-4 mb-5">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Mina sidor</h2>
            @if (Model != null)
            {
            <p class="text-muted small mt-1 mb-0">Välkommen tillbaka, @Model.FirstName @Model.LastName 👋</p>
            }
        </div>

        <div class="d-flex flex-wrap align-items-center gap-3">

            <div class="k-notifications shadow-sm" id="notificationBtn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>

                @{ var activeReminders = reminders.Where(r => !r.IsSent).ToList(); }
                @if (activeReminders.Any())
                {
                <span class="k-notification-badge">@activeReminders.Count</span>
                }

                <div class="k-popup" id="notificationPopup">
                    <div class="k-popup-header">
                        Påminnelser
                        <span class="status-badge badge-gray" style="font-size: 10px; padding: 2px 8px;">@activeReminders.Count st</span>
                    </div>
                    <div class="k-popup-body">
                        @if (!activeReminders.Any())
                        {
                        <div class="k-popup-item">
                            <span class="k-popup-item-title text-muted fw-medium">Inga påminnelser just nu.</span>
                        </div>
                        }
                        else
                        {
                        @foreach (var r in activeReminders)
                        {
                        var daysLeft = (r.DueDate - DateTime.Now).Days;
                        var isOverdue = r.DueDate < DateTime.Now;
                        string popupBadgeClass = isOverdue ? "badge-red" : daysLeft <= 3 ? "badge-yellow" : "badge-green";

                        <div class="k-popup-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="k-popup-item-title">@r.ItemTitle</span>
                                <span class="status-badge @popupBadgeClass" style="font-size: 10px; padding: 2px 8px;">
                                            @(isOverdue ? $"{Math.Abs(daysLeft)} d sen" : $"{daysLeft} d kvar")
                                        </span>
                            </div>
                            <span class="k-popup-item-date">Förfaller: @r.DueDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        }
                        }
                    </div>
                </div>
            </div>

            @if (Model != null)
            {
            <a asp-controller="MyPages" asp-action="EditProfile" class="btn btn-dark shadow-sm rounded-pill px-3 fw-medium">
                Ändra uppgifter
            </a>
            }

            <a asp-controller="Account" asp-action="SignOutUser" class="btn btn-outline-secondary shadow-sm rounded-pill px-3 fw-medium d-inline-flex align-items-center">
                <i class="bi bi-box-arrow-right me-2"></i> Logga ut
            </a>
        </div>
    </div>

    @if (Model != null)
    {
    <div class="card bg-white border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-6 col-md-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1 tracking-medium">Användarnamn</div>
                    <div class="fw-medium text-dark fs-6 text-break">@Model.Username</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1 tracking-medium">E-post</div>
                    <div class="fw-medium text-dark fs-6 text-break">@Model.Email</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1 tracking-medium">Förnamn</div>
                    <div class="fw-medium text-dark fs-6 text-break">@Model.FirstName</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1 tracking-medium">Efternamn</div>
                    <div class="fw-medium text-dark fs-6 text-break">@Model.LastName</div>
                </div>
            </div>
        </div>
    </div>
    }

    <div class="row g-4">

        <div class="col-lg-6">
            <h4 class="fw-bold mb-3 text-dark fs-5">Aktiva lån</h4>
            @if (!activeLoans.Any())
            {
            <div class="bg-white border rounded-4 p-4 text-center text-muted small shadow-sm">
                Inga aktiva lån just nu.
            </div>
            }
            else
            {
            <div class="table-container shadow-sm border-0">
                <table class="table mb-0 align-middle">
                    <thead>
                    <tr>
                        <th>Objekt</th>
                        <th>Lånat</th>
                        <th>Förfaller</th>
                        <th>Status</th>
                        <th class="text-end">ÅTGÄRDER</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var loan in activeLoans)
                    {
                    var daysLeft = (loan.DueAt - DateTimeOffset.Now).Days;
                    var isOverdue = loan.DueAt < DateTimeOffset.Now;
                    string loanBadgeClass = isOverdue ? "badge-red" : daysLeft <= 3 ? "badge-yellow" : "badge-green";

                    <tr>
                        <td class="fw-bold text-dark">@loan.ItemId</td>
                        <td>@loan.LoanedAt.ToString("yy-MM-dd")</td>
                        <td>@loan.DueAt.ToString("yy-MM-dd")</td>
                        <td>
                                        <span class="status-badge @loanBadgeClass">
                                            @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                        </span>
                        </td>
                        <td class="text-end">
                            <form asp-controller="MyPages" asp-action="ReturnItem" method="post" class="m-0">
                                <input type="hidden" name="loanId" value="@loan.Id" />
                                <input type="hidden" name="userId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />
                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Återlämna">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    }
                    </tbody>
                </table>
            </div>
            }
        </div>

        <div class="col-lg-6">
            <h4 class="fw-bold mb-3 text-dark fs-5">Bevakningar</h4>
            @if (!watches.Any())
            {
            <div class="bg-white border rounded-4 p-4 text-center text-muted small shadow-sm">
                Inga bevakningar just nu.
            </div>
            }
            else
            {
            <div class="table-container shadow-sm border-0">
                <table class="table mb-0 align-middle">
                    <thead>
                    <tr>
                        <th>Objekt</th>
                        <th>Status</th>
                        <th class="text-end">ÅTGÄRDER</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var w in watches)
                    {
                    string watchBadgeClass = w.IsActive ? "badge-green" : "badge-gray";

                    <tr>
                        <td class="fw-bold text-dark">@w.ItemTitle</td>
                        <td>
                                        <span class="status-badge @watchBadgeClass">
                                            @(w.IsActive ? "Tillgänglig" : "Bevakas")
                                        </span>
                        </td>
                        <td class="text-end">
                            <form asp-controller="MyPages" asp-action="StopWatch" method="post" class="m-0">
                                <input type="hidden" name="watchId" value="@w.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Sluta bevaka">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    }
                    </tbody>
                </table>
            </div>
            }
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const btn = document.getElementById("notificationBtn");
        const popup = document.getElementById("notificationPopup");

        if (btn && popup) {
            btn.addEventListener("click", function (e) {
                popup.classList.toggle("show");
                e.stopPropagation();
            });

            popup.addEventListener("click", function (e) {
                e.stopPropagation();
            });

            document.addEventListener("click", function () {
                popup.classList.remove("show");
            });
        }
    });
</script>
}