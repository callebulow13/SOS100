@model SOS100_MVC.Models.User?
@using SOS100_MVC.Models
@using SOS100_MVC.Dtos

@{
    ViewData["Title"] = "Mina sidor";
    var reminders = ViewBag.Reminders as List<Reminder> ?? new List<Reminder>();
    var watches = ViewBag.Watches as List<Watch> ?? new List<Watch>();
    var activeLoans = ViewBag.ActiveLoans as List<LoanDto> ?? new List<LoanDto>();
}

<style>
    body { background: #f5f4ef; }
    .mp-page { max-width: 1100px; margin: 40px auto; padding: 0 40px; font-family: 'DM Sans', sans-serif; }
    .mp-header { margin-bottom: 28px; }
    .mp-header h2 { font-size: 36px; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
    .mp-header p { color: #555; font-size: 15px; font-weight: 500; }
    .mp-card { background: white; border-radius: 16px; padding: 28px 32px; margin-bottom: 20px; box-shadow: 0 2px 12px rgba(99,102,241,0.08); border-top: 4px solid #6366f1; }
    .mp-card.loans { border-top-color: #6366f1; }
    .mp-card.reminders { border-top-color: #f59e0b; }
    .mp-card.watches { border-top-color: #10b981; }
    .mp-card.profile { border-top-color: #1a1a1a; }
    .mp-profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .mp-field label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #888; display: block; margin-bottom: 4px; font-weight: 600; }
    .mp-field span { font-size: 16px; color: #1a1a1a; font-weight: 700; }
    .mp-edit-btn { background: #6366f1; color: white; border: none; padding: 11px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
    .mp-edit-btn:hover { background: #4f46e5; color: white; }
    .mp-section-title { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: #333; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
    .mp-badge { background: #6366f1; color: white; font-size: 12px; padding: 3px 10px; border-radius: 20px; text-transform: none; letter-spacing: 0; font-weight: 700; }
    .mp-card.reminders .mp-badge { background: #f59e0b; }
    .mp-card.watches .mp-badge { background: #10b981; }
    .mp-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .mp-table thead tr { border-bottom: 2px solid #e8e8e8; }
    .mp-table th { text-align: left; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: #666; padding: 0 16px 12px 0; }
    .mp-table td { padding: 14px 16px 14px 0; border-bottom: 1px solid #f0f0f0; color: #1a1a1a; font-weight: 600; vertical-align: middle; }
    .mp-table tr:last-child td { border-bottom: none; }
    .mp-table tr.overdue td { color: #ef4444; }
    .mp-table tr:hover td { background: #fafafe; }
    .mp-tag { font-size: 12px; padding: 5px 13px; border-radius: 20px; white-space: nowrap; display: inline-block; font-weight: 700; }
    .mp-tag.red { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .mp-tag.indigo { background: #eef2ff; color: #4f46e5; border: 1px solid #c7d2fe; }
    .mp-tag.green { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .mp-tag.gray { background: #f5f5f5; color: #666; border: 1px solid #e5e5e5; }
    .mp-tag.amber { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .mp-empty { color: #999; font-size: 14px; font-weight: 600; padding: 8px 0; }
    .mp-return-btn { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; padding: 6px 16px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; }
    .mp-return-btn:hover { background: #fee2e2; }
    .mp-logout { color: #6366f1; font-size: 13px; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 4px; }
    .mp-logout:hover { color: #4f46e5; }
</style>

<div class="mp-page">

    <div class="mp-header">
        <h2>Mina sidor</h2>
        <div style="background: #ffcccc; padding: 10px; font-weight: bold; border: 2px solid red;">
            TEST: Mitt inloggade ID (NameIdentifier) är just nu: @User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
        </div>
        @if (Model != null)
        {
            <p>Välkommen tillbaka, @Model.FirstName @Model.LastName 👋</p>
        }
    </div>

    @if (Model != null)
    {
        <div class="mp-card profile">
            <div class="mp-profile-grid">
                <div class="mp-field"><label>Användarnamn</label><span>@Model.Username</span></div>
                <div class="mp-field"><label>E-post</label><span>@Model.Email</span></div>
                <div class="mp-field"><label>Förnamn</label><span>@Model.FirstName</span></div>
                <div class="mp-field"><label>Efternamn</label><span>@Model.LastName</span></div>
            </div>
            <a asp-controller="MyPages" asp-action="EditProfile" class="mp-edit-btn">Ändra uppgifter</a>
        </div>
    }

    <div class="mp-card loans">
        <div class="mp-section-title">📚 Mina aktiva lån <span class="mp-badge">@activeLoans.Count</span></div>
        @if (!activeLoans.Any())
        {
            <p class="mp-empty">Inga aktiva lån just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Objekt ID</th>
                        <th>Lånat</th>
                        <th>Förfaller</th>
                        <th>Dagar kvar</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in activeLoans)
                    {
                        var daysLeft = (loan.DueAt - DateTimeOffset.Now).Days;
                        var isOverdue = loan.DueAt < DateTimeOffset.Now;
                        <tr class="@(isOverdue ? "overdue" : "")">
                            <td>@loan.ItemId</td>
                            <td>@loan.LoanedAt.ToString("yyyy-MM-dd")</td>
                            <td>@loan.DueAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="mp-tag @(isOverdue ? "red" : daysLeft <= 3 ? "amber" : "green")">
                                    @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                </span>
                            </td>
                            <td>
                                <form asp-controller="TestProfile" asp-action="ReturnItem" method="post" style="margin:0">
                                    <input type="hidden" name="loanId" value="@loan.Id"/>
                                    <input type="hidden" name="userId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"/>
                                    <button type="submit" class="mp-return-btn">Återlämna</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="mp-card reminders">
        <div class="mp-section-title">🔔 Mina påminnelser <span class="mp-badge">@reminders.Count</span></div>
        @if (!reminders.Any())
        {
            <p class="mp-empty">Inga påminnelser just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Objekt</th>
                        <th>Förfaller</th>
                        <th>Dagar kvar</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in reminders.Where(r => !r.IsSent))
                    {
                        var daysLeft = (r.DueDate - DateTime.Now).Days;
                        var isOverdue = r.DueDate < DateTime.Now;
                        <tr class="@(isOverdue ? "overdue" : "")">
                            <td>@r.ItemTitle</td>
                            <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="mp-tag @(isOverdue ? "red" : daysLeft <= 3 ? "amber" : "green")">
                                    @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                </span>
                            </td>
                            <td>
                                <span class="mp-tag amber">
                                    ⏰ Väntar
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="mp-card watches">
        <div class="mp-section-title">👁️ Mina bevakningar <span class="mp-badge">@watches.Count</span></div>
        @if (!watches.Any())
        {
            <p class="mp-empty">Inga bevakningar just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                <tr>
                    <th>Objekt</th>
                    <th>Status</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var w in watches)
                {
                    <tr>
                        <td>@w.ItemTitle</td>
                        <td>
                            <span class="mp-tag @(w.IsActive ? "green" : "indigo")">
                                @(w.IsActive ? "✅ Tillgänglig" : "👁️ Bevakas")
                            </span>
                        </td>
                        <td>
                            <form asp-controller="MyPages" asp-action="StopWatch" method="post" style="margin:0">
                                <input type="hidden" name="watchId" value="@w.Id"/>
                                <button type="submit" class="mp-return-btn">Sluta bevaka</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <a asp-controller="Account" asp-action="SignOutUser" class="mp-logout">← Log out</a>
</div>