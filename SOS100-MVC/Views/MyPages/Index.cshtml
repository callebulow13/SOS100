@model SOS100_MVC.Models.User?
@using SOS100_MVC.Models
@using SOS100_MVC.Dtos

@{
    ViewData["Title"] = "Mina sidor";
    var reminders = ViewBag.Reminders as List<Reminder> ?? new List<Reminder>();
    var watches = ViewBag.Watches as List<Watch> ?? new List<Watch>();
    var activeLoans = ViewBag.ActiveLoans as List<LoanDto> ?? new List<LoanDto>();
}
<link rel="stylesheet" href="~/css/myPages.css" asp-append-version="true"/>



<div class="mp-page">

    <div class="mp-header">
        <h2>Mina sidor</h2>
        @if (Model != null)
        {
            <p>Välkommen tillbaka, @Model.FirstName @Model.LastName 👋</p>
        }
    </div>

    @if (Model != null)
    {
        <div class="mp-card profile">
            <div class="mp-profile-grid">
                <div class="mp-field"><label>Användarnamn</label><span>@Model.Username</span></div>
                <div class="mp-field"><label>E-post</label><span>@Model.Email</span></div>
                <div class="mp-field"><label>Förnamn</label><span>@Model.FirstName</span></div>
                <div class="mp-field"><label>Efternamn</label><span>@Model.LastName</span></div>
            </div>
            <a asp-controller="MyPages" asp-action="EditProfile" class="mp-edit-btn">Ändra uppgifter</a>
        </div>
    }

    <div class="mp-card loans">
        <div class="mp-section-title">📚 Mina aktiva lån <span class="mp-badge">@activeLoans.Count</span></div>
        @if (!activeLoans.Any())
        {
            <p class="mp-empty">Inga aktiva lån just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Objekt ID</th>
                        <th>Lånat</th>
                        <th>Förfaller</th>
                        <th>Dagar kvar</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in activeLoans)
                    {
                        var daysLeft = (loan.DueAt - DateTimeOffset.Now).Days;
                        var isOverdue = loan.DueAt < DateTimeOffset.Now;
                        <tr class="@(isOverdue ? "overdue" : "")">
                            <td>@loan.ItemId</td>
                            <td>@loan.LoanedAt.ToString("yyyy-MM-dd")</td>
                            <td>@loan.DueAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="mp-tag @(isOverdue ? "red" : daysLeft <= 3 ? "amber" : "green")">
                                    @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                </span>
                            </td>
                            <td>
                                <form asp-controller="MyPages" asp-action="ReturnItem" method="post" style="margin:0">
                                    <input type="hidden" name="loanId" value="@loan.Id"/>
                                    <input type="hidden" name="userId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"/>
                                    <button type="submit" class="mp-return-btn">Återlämna</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="mp-card reminders">
        <div class="mp-section-title">🔔 Mina påminnelser <span class="mp-badge">@activeLoans.Count</span></div>
        @if (!reminders.Any())
        {
            <p class="mp-empty">Inga påminnelser just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Objekt</th>
                        <th>Förfaller</th>
                        <th>Dagar kvar</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in reminders.Where(r => !r.IsSent))
                    {
                        var daysLeft = (r.DueDate - DateTime.Now).Days;
                        var isOverdue = r.DueDate < DateTime.Now;
                        <tr class="@(isOverdue ? "overdue" : "")">
                            <td>@r.ItemTitle</td>
                            <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="mp-tag @(isOverdue ? "red" : daysLeft <= 3 ? "amber" : "green")">
                                    @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                </span>
                            </td>
                            <td>
                                <span class="mp-tag amber">
                                    ⏰ Väntar
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="mp-card watches">
        <div class="mp-section-title">👁️ Mina bevakningar <span class="mp-badge">@watches.Count</span></div>
        @if (!watches.Any())
        {
            <p class="mp-empty">Inga bevakningar just nu.</p>
        }
        else
        {
            <table class="mp-table">
                <thead>
                <tr>
                    <th>Objekt</th>
                    <th>Status</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var w in watches)
                {
                    <tr>
                        <td>@w.ItemTitle</td>
                        <td>
                            <span class="mp-tag @(w.IsActive ? "green" : "indigo")">
                                @(w.IsActive ? "✅ Tillgänglig" : "👁️ Bevakas")
                            </span>
                        </td>
                        <td>
                            <form asp-controller="MyPages" asp-action="StopWatch" method="post" style="margin:0">
                                <input type="hidden" name="watchId" value="@w.Id"/>
                                <button type="submit" class="mp-return-btn">Sluta bevaka</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <a asp-controller="Account" asp-action="SignOutUser" class="mp-logout">← Log out</a>
</div>