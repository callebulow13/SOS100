@model SOS100_MVC.Models.Reports.ReportsPageViewModel

@{
    ViewData["Title"] = "Rapporter";
}

<div class="container-fluid">
    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1">Rapporter</h2>
        <p class="text-muted mb-0">
            Visa statistik och utlåningshistorik för bibliotekssystemet.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="bi bi-bar-chart-line text-primary fs-4"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0">Rapportval</h4>
                            <p class="text-secondary small mb-0">Välj rapport och ange parametrar.</p>
                        </div>
                    </div>

                    <form asp-action="Index" method="post" id="reportForm">
                        <div class="mb-3">
                            <label asp-for="SelectedReport" class="form-label fw-semibold">Typ av rapport</label>
                            <select asp-for="SelectedReport" class="form-select rounded-3">
                                <option value="">-- Välj rapport --</option>
                                <option value="most-loaned">Mest utlånade objekt</option>
                                <option value="overdue">Antal försenade lån</option>
                                <option value="current-loaned">Nuvarande utlånade objekt</option>
                                <option value="item-history">Utlåningshistorik per objekt</option>
                                <option value="user-history">Utlåningshistorik per användare</option>
                            </select>
                        </div>

                        <div id="reportDescription" class="small text-muted mb-3 p-3 bg-light rounded-3 border">
                            Välj en rapport för att se vilka parametrar som behövs.
                        </div>

                        <div id="itemSearchGroup" class="mb-3 d-none">
                            <label class="form-label fw-semibold d-block">Sök objekt</label>

                            <div class="row g-2 align-items-center">
                                <div class="col-md-5">
                                    <input asp-for="ItemId" class="form-control rounded-3" placeholder="Objekt-ID" />
                                    <span asp-validation-for="ItemId" class="text-danger small"></span>
                                </div>

                                <div class="col-md-2 text-center">
                                    <span class="fw-semibold text-muted">eller</span>
                                </div>

                                <div class="col-md-5">
                                    <input asp-for="ItemName" class="form-control rounded-3" placeholder="Objektnamn" />
                                    <span asp-validation-for="ItemName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div id="userSearchGroup" class="mb-3 d-none">
                            <label class="form-label fw-semibold d-block">Sök användare</label>

                            <div class="row g-2 align-items-center">
                                <div class="col-md-5">
                                    <input asp-for="UserId" class="form-control rounded-3" placeholder="Användar-ID" />
                                    <span asp-validation-for="UserId" class="text-danger small"></span>
                                </div>

                                <div class="col-md-2 text-center">
                                    <span class="fw-semibold text-muted">eller</span>
                                </div>

                                <div class="col-md-5">
                                    <input asp-for="UserName" class="form-control rounded-3" placeholder="Användarnamn" />
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div id="mostLoanedLimitGroup" class="mb-4 d-none">
                            <label class="form-label fw-semibold d-block">Antal resultat</label>

                            <div class="d-flex gap-2 flex-wrap">
                                <input type="radio" class="btn-check" name="mostLoanedLimitOption" id="limit20" value="20" autocomplete="off" checked>
                                <label class="btn btn-outline-primary rounded-pill px-3" for="limit20">20</label>

                                <input type="radio" class="btn-check" name="mostLoanedLimitOption" id="limit40" value="40" autocomplete="off">
                                <label class="btn btn-outline-primary rounded-pill px-3" for="limit40">40</label>

                                <input type="radio" class="btn-check" name="mostLoanedLimitOption" id="limit80" value="80" autocomplete="off">
                                <label class="btn btn-outline-primary rounded-pill px-3" for="limit80">80</label>

                                <input type="radio" class="btn-check" name="mostLoanedLimitOption" id="limitAll" value="all" autocomplete="off">
                                <label class="btn btn-outline-primary rounded-pill px-3" for="limitAll">Alla</label>
                            </div>

                            <input type="hidden" asp-for="MostLoanedLimit" id="MostLoanedLimit" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="submitButton" class="btn btn-dark rounded-pill fw-semibold shadow-sm" disabled>
                                Välj först en rapport
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="bi bi-file-earmark-bar-graph text-success fs-4"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0">Rapportresultat</h4>
                        </div>
                    </div>

                    @if (string.IsNullOrWhiteSpace(Model.SelectedReport))
                    {
                        <div class="border rounded-4 p-5 bg-light text-center">
                            <i class="bi bi-bar-chart text-secondary fs-1 d-block mb-3"></i>
                            <h5 class="fw-bold">Ingen rapport vald ännu</h5>
                            <p class="text-muted mb-0">
                                Välj en rapport i formuläret till vänster för att visa statistik eller historik.
                            </p>
                        </div>
                    }

                    @if (Model.SelectedReport == "most-loaned")
                    {
                        <div class="mb-3">
                            <h5 class="fw-bold mb-1">Mest utlånade objekt</h5>
                            <p class="text-muted small mb-0">Visar de mest utlånade objekten i systemet.</p>
                        </div>

                        @if (Model.MostLoanedItems.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Objekt-ID</th>
                                            <th>Objekt</th>
                                            <th class="text-end">Antal lån</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.MostLoanedItems)
                                        {
                                            <tr>
                                                <td class="text-muted">@item.ItemId</td>
                                                <td class="fw-semibold">@item.ItemTitle</td>
                                                <td class="text-end fw-bold">@item.LoanCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info rounded-3 mb-0">
                                Ingen data att visa för denna rapport.
                            </div>
                        }
                    }

                    @if (Model.SelectedReport == "overdue")
                    {
                        <div class="mb-3">
                            <h5 class="fw-bold mb-1">Antal försenade lån</h5>
                            <p class="text-muted small mb-0">Översikt över lån som ännu inte har återlämnats i tid.</p>
                        </div>

                        @if (Model.OverdueLoanCount.HasValue)
                        {
                            <div class="row">
                                <div class="col-sm-8 col-md-6">
                                    <div class="border rounded-4 p-4 bg-light">
                                        <div class="text-muted small mb-2">Försenade lån</div>
                                        <div class="display-5 fw-bold text-warning">@Model.OverdueLoanCount</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger rounded-3 mb-0">
                                Kunde inte hämta rapporten.
                            </div>
                        }
                    }
                    
                    @if (Model.SelectedReport == "current-loaned")
                    {
                        <div class="mb-3">
                            <h5 class="fw-bold mb-1">Nuvarande utlånade objekt</h5>
                            <p class="text-muted small mb-0">
                                Visar objekt som för närvarande är utlånade samt vem som lånar dem.
                            </p>
                        </div>

                        @if (Model.CurrentLoanedItems.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Objekt-ID</th>
                                        <th>Objektnamn</th>
                                        <th>Användare</th>
                                        <th>Utlånad</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var loan in Model.CurrentLoanedItems)
                                    {
                                        <tr>
                                            <td class="text-muted">@loan.ItemId</td>
                                            <td class="fw-semibold">@loan.ItemName</td>
                                            <td>@loan.UserName</td>
                                            <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info rounded-3 mb-0">
                                Det finns inga objekt som är utlånade just nu.
                            </div>
                        }
                    }

                    @if (Model.SelectedReport == "item-history")
                    {
                        <div class="mb-3">
                            <h5 class="fw-bold mb-1">Utlåningshistorik per objekt</h5>
                            <p class="text-muted small mb-0">Visar historik för valt objekt.</p>
                        </div>

                        @if (Model.ItemLoanHistory.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Lån-ID</th>
                                            <th>Användare</th>
                                            <th>Utlånad</th>
                                            <th>Förfallodatum</th>
                                            <th>Återlämnad</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var loan in Model.ItemLoanHistory)
                                        {
                                            <tr>
                                                <td class="text-muted">@loan.LoanId</td>
                                                <td class="fw-semibold">@loan.UserName</td>
                                                <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                                                <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                                <td>
                                                    @if (loan.ReturnedDate.HasValue)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border rounded-pill px-3 py-2">
                                                            @loan.ReturnedDate.Value.ToString("yyyy-MM-dd")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning-subtle text-dark border rounded-pill px-3 py-2">
                                                            Inte återlämnad
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info rounded-3 mb-0">
                                Ingen historik hittades för valt objekt.
                            </div>
                        }
                    }

                    @if (Model.SelectedReport == "user-history")
                    {
                        <div class="mb-3">
                            <h5 class="fw-bold mb-1">Utlåningshistorik per användare</h5>
                            <p class="text-muted small mb-0">Visar historik för vald användare.</p>
                        </div>

                        @if (Model.UserLoanHistory.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Lån-ID</th>
                                            <th>Objekt</th>
                                            <th>Utlånad</th>
                                            <th>Förfallodatum</th>
                                            <th>Återlämnad</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var loan in Model.UserLoanHistory)
                                        {
                                            <tr>
                                                <td class="text-muted">@loan.LoanId</td>
                                                <td class="fw-semibold">@loan.ItemTitle</td>
                                                <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                                                <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                                <td>
                                                    @if (loan.ReturnedDate.HasValue)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border rounded-pill px-3 py-2">
                                                            @loan.ReturnedDate.Value.ToString("yyyy-MM-dd")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning-subtle text-dark border rounded-pill px-3 py-2">
                                                            Inte återlämnad
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info rounded-3 mb-0">
                                Ingen historik hittades för vald användare.
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const reportSelect = document.getElementById("SelectedReport");
            const itemSearchGroup = document.getElementById("itemSearchGroup");
            const userSearchGroup = document.getElementById("userSearchGroup");
            const mostLoanedLimitGroup = document.getElementById("mostLoanedLimitGroup");

            const itemIdInput = document.getElementById("ItemId");
            const itemNameInput = document.getElementById("ItemName");
            const userIdInput = document.getElementById("UserId");
            const userNameInput = document.getElementById("UserName");
            const mostLoanedLimitInput = document.getElementById("MostLoanedLimit");

            const submitButton = document.getElementById("submitButton");
            const reportDescription = document.getElementById("reportDescription");

            const limitOptions = document.querySelectorAll("input[name='mostLoanedLimitOption']");

            function hideAllFields() {
                itemSearchGroup.classList.add("d-none");
                userSearchGroup.classList.add("d-none");
                mostLoanedLimitGroup.classList.add("d-none");

                itemIdInput.required = false;
                itemNameInput.required = false;
                userIdInput.required = false;
                userNameInput.required = false;
            }

            function syncMostLoanedLimit() {
                const selected = document.querySelector("input[name='mostLoanedLimitOption']:checked");

                if (!selected) {
                    mostLoanedLimitInput.value = "20";
                    return;
                }

                if (selected.value === "all") {
                    mostLoanedLimitInput.value = "";
                } else {
                    mostLoanedLimitInput.value = selected.value;
                }
            }

            function setSelectedLimitFromModel() {
                const currentValue = mostLoanedLimitInput.value;

                if (currentValue === "") {
                    const allOption = document.getElementById("limitAll");
                    if (allOption) allOption.checked = true;
                    return;
                }

                const option = document.querySelector(`input[name='mostLoanedLimitOption'][value='${currentValue}']`);
                if (option) {
                    option.checked = true;
                } else {
                    const defaultOption = document.getElementById("limit20");
                    if (defaultOption) defaultOption.checked = true;
                    mostLoanedLimitInput.value = "20";
                }
            }

            function updateForm() {
                const selectedReport = reportSelect.value;

                hideAllFields();

                switch (selectedReport) {
                    case "most-loaned":
                        reportDescription.textContent = "Välj hur många av de mest utlånade objekten du vill visa, eller Alla för hela listan.";
                        mostLoanedLimitGroup.classList.remove("d-none");
                        submitButton.disabled = false;
                        submitButton.textContent = "Visa rapport";
                        syncMostLoanedLimit();
                        break;

                    case "overdue":
                        reportDescription.textContent = "Visar antal lån som är försenade just nu.";
                        submitButton.disabled = false;
                        submitButton.textContent = "Visa rapport";
                        break;

                    case "current-loaned":
                        reportDescription.textContent = "Visar alla objekt som för närvarande är utlånade.";
                        submitButton.disabled = false;
                        submitButton.textContent = "Visa rapport";
                        break;

                    case "item-history":
                        reportDescription.textContent = "Ange objekt-ID eller objektnamn för att visa utlåningshistorik för ett specifikt objekt.";
                        itemSearchGroup.classList.remove("d-none");
                        submitButton.disabled = false;
                        submitButton.textContent = "Visa objekthistorik";
                        break;

                    case "user-history":
                        reportDescription.textContent = "Ange användar-ID eller användarnamn för att visa utlåningshistorik för en specifik användare.";
                        userSearchGroup.classList.remove("d-none");
                        submitButton.disabled = false;
                        submitButton.textContent = "Visa användarhistorik";
                        break;

                    default:
                        reportDescription.textContent = "Välj en rapport för att se vilka parametrar som behövs.";
                        submitButton.disabled = true;
                        submitButton.textContent = "Välj en rapport";
                        break;
                }
            }

            limitOptions.forEach(option => {
                option.addEventListener("change", syncMostLoanedLimit);
            });

            reportSelect.addEventListener("change", updateForm);

            setSelectedLimitFromModel();
            updateForm();
        });
    </script>
}