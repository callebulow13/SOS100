<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Bibliotek Dashboard</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SOS100_MVC.styles.css" asp-append-version="true"/>
    
    <style>
        /* Global bakgrundsfärg för dashboard-känslan */
        body {
            background-color: #f4f7f6;
        }
        
        /* Sidebar styling */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        
        .sidebar .nav-link {
            border-radius: 0.5rem;
            margin-bottom: 0.2rem;
            color: #495057;
            transition: all 0.2s;
        }
        
        .sidebar .nav-link:hover {
            background-color: #e9ecef;
            color: #0d6efd;
            transform: translateX(4px);
        }
        
        /* Huvudinnehållets höjd */
        .main-content {
            min-height: 100vh;
        }
    </style>
</head>
<body>

<div class="d-flex">
    <aside class="sidebar bg-white border-end shadow-sm d-none d-md-flex flex-column p-3">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="d-flex align-items-center mb-4 mt-2 text-dark text-decoration-none">
            <i class="bi bi-box-seam text-primary fs-3 me-2"></i>
            <span class="fs-4 fw-bold">Bibliotek</span>
        </a>
        
        <hr class="text-secondary opacity-25 mt-0">

        <ul class="nav flex-column mb-auto fw-medium">
            <li class="nav-item">
                <a class="nav-link px-3 py-2" asp-area="" asp-controller="Catalog" asp-action="Index">
                    <i class="bi bi-journal-text me-2"></i> Katalogen
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link px-3 py-2" asp-area="" asp-controller="Reports" asp-action="Index">
                    <i class="bi bi-bar-chart-line me-2"></i> Rapporter
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link px-3 py-2" asp-area="" asp-controller="MyPages" asp-action="Index">
                    <i class="bi bi-person-badge me-2"></i> Mina sidor
                </a>
            </li>

            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <li class="nav-item mt-3">
                    <span class="text-muted small fw-bold text-uppercase px-3">Administration</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 py-2 text-danger" asp-area="" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-shield-lock me-2"></i> Admin-panel
                    </a>
                </li>
            }
        </ul>
        
        
        <div class="mt-auto border-top pt-3 text-center">
            <small class="text-muted">&copy; 2026 SOS100</small>
        </div>
    </aside>

    <div class="flex-grow-1 d-flex flex-column main-content">
        
        <nav class="navbar navbar-light bg-white border-bottom shadow-sm d-md-none px-3">
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam text-primary me-1"></i> Bibliotek
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse mt-2" id="mobileMenu">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-controller="Catalog" asp-action="Index">Katalogen</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Reports" asp-action="Index">Rapporter</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="MyPages" asp-action="Index">Mina sidor</a></li>
                </ul>
                
            </div>
        </nav>

        <main role="main" class="p-4 p-md-5">
            @RenderBody()
        </main>
        
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>