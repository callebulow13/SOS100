@model SOS100_MVC.Models.ProfileViewModel

@{
    ViewData["Title"] = "Test Mina sidor (Design)";

    // Vi kan ha kvar fiktiva påminnelser tills ni bygger en ReminderService
    var myReminders = new[]
    {
        new { Message = "Bärbar Projektor är försenad! Vänligen återlämna.", SentDate = DateTime.Now.AddDays(-1) }
    };
}

<div class="container mt-4 mb-5">
    @if (ViewBag.DebugMessage != null)
    {
        <div class="alert @(ViewBag.DebugMessage.Contains("FEL") ? "alert-danger" : "alert-info") shadow-sm rounded-3 mb-4 fw-medium">
            <i class="bi bi-bug me-2"></i> @ViewBag.DebugMessage
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 mb-4 fw-medium">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        </div>
    }
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="profile-avatar"><i class="bi bi-person"></i></div>
                    </div>
                    
                    <h4 class="fw-bold mb-1">@Model.User.FirstName @Model.User.LastName</h4>
                    <span class="badge bg-primary-subtle text-primary rounded-pill mb-3">@Model.User.Role</span>
                    
                    <hr class="text-muted opacity-25">
                    
                    <div class="text-start">
                        <div class="mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Användarnamn</small>
                            <div class="fw-medium">@Model.User.Username</div>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">E-post</small>
                            <div class="fw-medium">@Model.User.Email</div>
                        </div>
                    </div>
                </div>
            </div>
            
            </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 d-flex align-items-center">
                        <i class="bi bi-collection me-2 text-primary"></i> Aktiva lån
                    </h5>
                    <span class="badge bg-light text-dark border">@Model.ActiveLoans.Count() st</span>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase" style="font-size: 0.8rem;">
                                <tr>
                                    <th class="ps-4 py-3 border-bottom-0">Objekt ID</th>
                                    <th class="py-3 border-bottom-0">Lånedatum</th>
                                    <th class="py-3 border-bottom-0">Återlämning</th>
                                    <th class="pe-4 py-3 border-bottom-0 text-end">Åtgärd</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.ActiveLoans)
                                {
                                    bool isLate = loan.DueAt < DateTimeOffset.UtcNow;
                                    string dateColor = isLate ? "text-danger fw-bold" : "text-dark";

                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-box fs-4 text-muted me-3"></i>
                                                <div>
                                                    <div class="fw-bold text-dark">Objekt #@loan.ItemId</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-3 text-secondary">@loan.LoanedAt.ToString("yyyy-MM-dd")</td>
                                        <td class="py-3 @dateColor">
                                            @if (isLate) { <i class="bi bi-exclamation-circle me-1"></i> }
                                            @loan.DueAt.ToString("yyyy-MM-dd")
                                        </td>
                                        <td class="pe-4 py-3 text-end">
                                            <form asp-controller="TestProfile" asp-action="ReturnItem" method="post" class="m-0">
        
                                                <input type="hidden" name="loanId" value="@loan.Id" />
                                                <input type="hidden" name="userId" value="@Model.User.UserID" />
        
                                                <button type="submit" class="btn btn-sm btn-outline-success rounded-pill fw-medium shadow-sm">
                                                    <i class="bi bi-arrow-return-left me-1"></i> Återlämna
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        @if (!Model.ActiveLoans.Any())
                        {
                            <div class="text-center p-5">
                                <i class="bi bi-emoji-smile fs-1 text-muted mb-3 d-block"></i>
                                <h6 class="text-secondary fw-medium">Du har inga aktiva lån just nu.</h6>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>