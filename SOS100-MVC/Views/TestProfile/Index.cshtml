@{
    ViewData["Title"] = "Test Mina sidor (Design)";

    // --- FIKTIV DATA BARA FÖR DESIGN-TEST ---
    var currentUser = new { 
        FirstName = "Anna", 
        LastName = "Andersson", 
        Username = "anna.andersson", 
        Email = "anna.andersson@kommunen.se", 
        Role = "Medarbetare" 
    };
    
    var myLoans = new[]
    {
        new { ItemName = "C# för nybörjare", Category = "Bok", LoanDate = DateTime.Now.AddDays(-10), ReturnDate = DateTime.Now.AddDays(4), IsLate = false },
        new { ItemName = "Bärbar Projektor", Category = "Elektronik", LoanDate = DateTime.Now.AddDays(-20), ReturnDate = DateTime.Now.AddDays(-5), IsLate = true }
    };

    var myReminders = new[]
    {
        new { Message = "Bärbar Projektor är försenad! Vänligen återlämna till IT-supporten.", SentDate = DateTime.Now.AddDays(-1) }
    };
    // ------------------------------------------
}

<style>
    body {
        background-color: #f4f7f6;
    }
    
    .profile-avatar {
        width: 80px;
        height: 80px;
        background-color: #e9ecef;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: #6c757d;
    }
</style>

<div class="container mt-4 mb-5">
    
    <div class="mb-4">
        <h2 class="fw-bold mb-0 text-dark">Mina sidor (Design-Test)</h2>
        <p class="text-muted small">Din personliga översikt över lån och profiluppgifter.</p>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-4">
            
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="profile-avatar">
                            <i class="bi bi-person"></i>
                        </div>
                    </div>
                    
                    <h4 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h4>
                    <span class="badge bg-primary-subtle text-primary rounded-pill mb-3">@Model.Role</span>
                    
                    <hr class="text-muted opacity-25">
                    
                    <div class="text-start">
                        <div class="mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Användarnamn</small>
                            <div class="fw-medium">@Model.Username</div>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">E-post</small>
                            <div class="fw-medium">@Model.Email</div>
                        </div>
                    </div>
                    
                    <div class="mt-4 pt-3 border-top">
                        <button class="btn btn-outline-secondary btn-sm rounded-pill w-100 fw-medium">
                            <i class="bi bi-pencil-square me-1"></i> Redigera profil (Mock)
                        </button>
                    </div>
                </div>
            </div>

            @if (myReminders.Any())
            {
                <div class="card shadow-sm border-0 border-start border-danger border-4 rounded-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold text-danger mb-3 d-flex align-items-center">
                            <i class="bi bi-bell-fill me-2"></i> Påminnelser
                        </h6>
                        
                        @foreach (var reminder in myReminders)
                        {
                            <div class="alert alert-danger bg-danger-subtle border-0 rounded-3 small mb-2">
                                <strong>@reminder.SentDate.ToShortDateString():</strong> @reminder.Message
                            </div>
                        }
                    </div>
                </div>
            }

        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 d-flex align-items-center">
                        <i class="bi bi-collection me-2 text-primary"></i> Aktiva lån
                    </h5>
                    <span class="badge bg-light text-dark border">@myLoans.Count() st</span>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase" style="font-size: 0.8rem;">
                                <tr>
                                    <th class="ps-4 py-3 border-bottom-0">Objekt</th>
                                    <th class="py-3 border-bottom-0">Lånedatum</th>
                                    <th class="py-3 border-bottom-0">Återlämning</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in myLoans)
                                {
                                    string dateColor = loan.IsLate ? "text-danger fw-bold" : "text-dark";
                                    string icon = loan.Category == "Elektronik" ? "bi-laptop" : "bi-book";

                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <i class="bi @icon fs-4 text-muted me-3"></i>
                                                <div>
                                                    <div class="fw-bold text-dark">@loan.ItemName</div>
                                                    <small class="text-muted">@loan.Category</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-3 text-secondary">@loan.LoanDate.ToShortDateString()</td>
                                        <td class="py-3 @dateColor">
                                            @if (loan.IsLate)
                                            {
                                                <i class="bi bi-exclamation-circle me-1"></i>
                                            }
                                            @loan.ReturnDate.ToShortDateString()
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>